<Window x:Class="LibraryManager.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Library Manager"
        Height="650"
        Width="900">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ================= FILTERS ================= -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

            <TextBlock Text="Title:" VerticalAlignment="Center" Margin="5"/>

            <TextBox Width="150"
                     Margin="5"
                     Text="{Binding TitleFilter, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Artist:" VerticalAlignment="Center" Margin="5"/>

            <TextBox Width="150"
                     Margin="5"
                     Text="{Binding ArtistFilter, UpdateSourceTrigger=PropertyChanged}"/>

            <Button Content="Search"
                    Width="100"
                    Margin="10,5,0,5"
                    Click="Search_Click"/>

        </StackPanel>

        <!-- ================= SONGS ================= -->
        <GroupBox Header="Songs"
                  Grid.Row="1"
                  Margin="0,0,0,10">

            <DataGrid x:Name="SongsGrid"
                      ItemsSource="{Binding Songs}"
                      SelectedItem="{Binding SelectedSong}"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"/>
        </GroupBox>

        <!-- ================= FAVORITES (LOGGED USER ONLY) ================= -->
        <GroupBox Header="My Favorites"
                  Grid.Row="2">

            <!-- 🔥 CHANGE: instead of Users grid -->
            <DataGrid x:Name="FavoritesGrid"
                      ItemsSource="{Binding FavoriteSongs}"
                      SelectedItem="{Binding SelectedFavoriteSong}"
                      AutoGenerateColumns="True"
                      IsReadOnly="True" SelectionChanged="FavoritesGrid_SelectionChanged"/>
        </GroupBox>

        <!-- ================= ACTION BUTTONS ================= -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0">

            <Button Content="➕ Add to Favorites"
                    Width="200"
                    Margin="5"
                    Height="40"
                    Click="AddFavorite_Click"/>

            <!-- 🔥 NEW BUTTON -->
            <Button Content="➖ Remove from Favorites"
                    Width="200"
                    Margin="5"
                    Height="40"
                    Click="RemoveFavorite_Click"/>

        </StackPanel>

    </Grid>
</Window>